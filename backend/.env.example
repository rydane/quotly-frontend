# ─── DEFACT — Variables d'environnement ──────────────────────────────────────
# COPIE ce fichier en `.env` et remplace les valeurs.
# Le fichier `.env` ne sera JAMAIS poussé sur GitHub (cf .gitignore).
# Sur Render, ajoute ces variables une par une dans Settings → Environment.
# ─────────────────────────────────────────────────────────────────────────────

PORT=3001
NODE_ENV=production

# ⚠️  L'URL de TON frontend (Vercel ou domaine perso une fois acheté)
FRONTEND_URL=https://defact.fr

# ⚠️  Génère un secret JWT aléatoire (>= 32 caractères) :
#    node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REMPLACE_PAR_SECRET_ALEATOIRE_64_HEX
JWT_EXPIRES_IN=7d

# ─── PostgreSQL (Supabase recommandé — gratuit jusqu'à 500 Mo) ───────────────
# Supabase → Project Settings → Database → Connection string → URI
# Format : postgresql://postgres:MOT_DE_PASSE@db.xxxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:CHANGE_ME@db.xxxxx.supabase.co:5432/postgres

# ─── Email transactionnel (Gmail App Password) ───────────────────────────────
# Active la 2FA sur ton compte Gmail puis : https://myaccount.google.com/apppasswords
# Limite Gmail = 100 emails/jour. Au-delà, passe à Resend ou SendGrid.
GMAIL_USER=ton.email@gmail.com
GMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM=DEFACT <ton.email@gmail.com>

# ─── PayPal (paiements) ──────────────────────────────────────────────────────
# Récupère ces valeurs dans : https://developer.paypal.com/dashboard
PAYPAL_WEBHOOK_ID=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=live
PAYPAL_PLAN_PRO=SLGH8N66YPCAQ
PAYPAL_PLAN_TEAM=BXFT9S9669PWY

# ─── Upload de logos clients ─────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ─── PDP (Plateforme Agréée DGFiP) — facturation électronique 2026 ───────────
# Reste sur 'none' tant que tu n'as pas signé de partenariat avec Tiime/Abby/Sellsy.
# Voir backend/services/pdp-integration.js pour les détails d'intégration.
PDP_PROVIDER=none
PDP_API_URL=
PDP_API_KEY=
PDP_MERCHANT_ID=
